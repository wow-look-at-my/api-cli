{
  "name": "api-cli-workers",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers port of api-cli — parses the same JSON config and serves leaf commands as HTTP endpoints using fetch().",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run && vitest run --config vitest.node.config.ts",
    "test:workers": "vitest run",
    "test:comparative": "vitest run --config vitest.node.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250508.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1",
    "wrangler": "^4.14.0"
  }
}
