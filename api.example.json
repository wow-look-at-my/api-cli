{
  "$schema": "./api.schema.json",
  "name": "apicli",
  "description": "Declarative alias CLI for https://jsonplaceholder.typicode.com — a public fake REST API. Every leaf renders the root `command` template by default; override on a leaf for anything that doesn't fit the pattern (see `posts create`).",

  "vars": {
    "base_url": "https://jsonplaceholder.typicode.com"
  },

  "command": "curl -fsSL -H 'Accept: application/json' {{.var.base_url}}{{.entry.path}}{{querystring .entry.query}}",

  "formats": {
    "user": {
      "input": "json",
      "when": "{{.tty}}",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"ID\\tNAME\\tUSERNAME\\tEMAIL\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\" .id .name .username .email) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "ID:       {{.data.id}}\nName:     {{.data.name}}\nUsername: {{.data.username}}\nEmail:    {{.data.email}}\nPhone:    {{.data.phone}}\nWebsite:  {{.data.website}}\n"
        }
      ]
    }
  },

  "commands": [
    {
      "name": "users",
      "description": "Work with users.",
      "format": "user",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a user by ID.",
          "args": [
            { "name": "id", "type": "int", "required": true, "description": "Numeric user ID." }
          ],
          "entry": {
            "path": "/users/{{.arg.id}}"
          }
        },
        {
          "name": "list",
          "description": "List users.",
          "flags": [
            { "name": "limit", "short": "l", "type": "int", "default": 10, "description": "Max results." },
            { "name": "pretty", "type": "bool", "default": true, "description": "Pretty-print JSON output (use --no-pretty to disable)." }
          ],
          "command": "curl -fsSL -H 'Accept: application/json' {{.var.base_url}}/users{{querystring .entry.query}}{{if .flag.pretty}} | jq .{{end}}",
          "entry": {
            "query": { "_limit": "{{.flag.limit}}" }
          }
        },
        {
          "name": "batch",
          "description": "Fetch multiple users by ID. Demonstrates variadic args + the `spread` helper in argv form: each ID becomes its own curl invocation via xargs.",
          "args": [
            { "name": "ids", "type": "int", "required": true, "variadic": true, "description": "One or more user IDs." }
          ],
          "command": [
            "sh", "-c",
            "for id in {{spread .arg.ids}}; do curl -fsSL -H 'Accept: application/json' \"{{.var.base_url}}/users/$id\"; done"
          ]
        },
        {
          "name": "save",
          "description": "Save a user record to a local file. Demonstrates preconditions (refuse to overwrite) and a templated default (--out defaults to user-<id>.json).",
          "args": [
            { "name": "id", "type": "int", "required": true, "description": "Numeric user ID." }
          ],
          "flags": [
            { "name": "out", "short": "o", "type": "string", "default": "user-{{.arg.id}}.json", "description": "Output file path." },
            { "name": "force", "short": "f", "type": "bool", "description": "Overwrite an existing file." }
          ],
          "preconditions": [
            "{{if and (fileExists .flag.out) (not .flag.force)}}{{.flag.out}} already exists; pass --force to overwrite{{end}}"
          ],
          "command": "curl -fsSL -H 'Accept: application/json' {{.var.base_url}}/users/{{.arg.id}} -o {{shellquote .flag.out}}"
        }
      ]
    },

    {
      "name": "posts",
      "description": "Work with posts.",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a post by ID.",
          "args": [
            { "name": "id", "type": "int", "required": true, "description": "Numeric post ID." }
          ],
          "entry": {
            "path": "/posts/{{.arg.id}}"
          }
        },
        {
          "name": "list",
          "description": "List posts, optionally filtered by user.",
          "flags": [
            { "name": "user", "short": "u", "type": "int", "default": 0, "description": "Filter by user ID; 0 means all." }
          ],
          "entry": {
            "path": "/posts",
            "query": { "userId": "{{if .flag.user}}{{.flag.user}}{{end}}" }
          }
        },
        {
          "name": "create",
          "description": "Create a new post. Overrides the root curl template to send a JSON body — argv form sidesteps shell-quoting entirely.",
          "flags": [
            { "name": "title", "short": "t", "type": "string", "required": true, "description": "Post title." },
            { "name": "body", "short": "b", "type": "string", "required": true, "description": "Post body text." },
            { "name": "user", "short": "u", "type": "int", "default": 1, "description": "Author user ID." }
          ],
          "command": [
            "curl", "-fsSL",
            "-X", "POST",
            "-H", "Content-Type: application/json",
            "-d", "{\"title\":{{.flag.title | toJson}},\"body\":{{.flag.body | toJson}},\"userId\":{{.flag.user}}}",
            "{{.var.base_url}}/posts"
          ]
        }
      ]
    },

    {
      "name": "user-posts",
      "description": "List posts for a user looked up by username (demonstrates steps / result reuse). Runs 2 API calls: first resolves the username to an ID, then fetches that user's posts.",
      "args": [
        { "name": "username", "type": "string", "required": true, "description": "Username to look up (e.g. Bret)." }
      ],
      "steps": [
        {
          "name": "user",
          "entry": { "path": "/users", "query": { "username": "{{.arg.username}}" } }
        }
      ],
      "entry": {
        "path": "/posts",
        "query": { "userId": "{{(index .result.user 0).id}}" }
      }
    },

    {
      "name": "user-or-id",
      "description": "Fetch a user by numeric ID or username (demonstrates conditional steps). If the argument looks like a number, use it directly; otherwise resolve the username first.",
      "args": [
        { "name": "id", "type": "string", "required": true, "description": "Numeric user ID or username." }
      ],
      "steps": [
        {
          "name": "resolved",
          "when": "{{not (regexMatch `^[0-9]+$` .arg.id)}}",
          "entry": { "path": "/users", "query": { "username": "{{.arg.id}}" } }
        }
      ],
      "entry": {
        "path": "/users/{{if .result.resolved}}{{(index .result.resolved 0).id}}{{else}}{{.arg.id}}{{end}}"
      },
      "format": "user"
    }
  ]
}
