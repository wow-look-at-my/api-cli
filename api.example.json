{
  "name": "apicli",
  "short": "JSON-driven CLI for jsonplaceholder.typicode.com (example).",
  "long": "This example config talks to https://jsonplaceholder.typicode.com — a public fake REST API. Replace base_url and paths to point at your own API.",
  "defaults": {
    "base_url": "https://jsonplaceholder.typicode.com",
    "headers": {
      "Accept": "application/json"
    }
  },
  "commands": [
    {
      "name": "users",
      "short": "Work with users.",
      "commands": [
        {
          "name": "get",
          "short": "Fetch a user by ID.",
          "args": [
            { "name": "id", "type": "int", "required": true, "description": "Numeric user ID." }
          ],
          "request": {
            "method": "GET",
            "path": "/users/{{.id}}"
          }
        },
        {
          "name": "list",
          "short": "List users.",
          "flags": [
            { "name": "limit", "short": "l", "type": "int", "default": 10, "description": "Max results to return." }
          ],
          "request": {
            "method": "GET",
            "path": "/users",
            "query": { "_limit": "{{.limit}}" }
          }
        }
      ]
    },
    {
      "name": "posts",
      "short": "Work with posts.",
      "commands": [
        {
          "name": "get",
          "short": "Fetch a post by ID.",
          "args": [
            { "name": "id", "type": "int", "required": true, "description": "Numeric post ID." }
          ],
          "request": {
            "method": "GET",
            "path": "/posts/{{.id}}"
          }
        },
        {
          "name": "list",
          "short": "List posts, optionally filtered by user.",
          "flags": [
            { "name": "user", "short": "u", "type": "int", "default": 0, "description": "Filter by user ID; 0 means all." }
          ],
          "request": {
            "method": "GET",
            "path": "/posts",
            "query": { "userId": "{{if .user}}{{.user}}{{end}}" }
          }
        },
        {
          "name": "create",
          "short": "Create a new post.",
          "flags": [
            { "name": "title", "short": "t", "type": "string", "required": true, "description": "Post title." },
            { "name": "body", "short": "b", "type": "string", "required": true, "description": "Post body text." }
          ],
          "request": {
            "method": "POST",
            "path": "/posts",
            "body": {
              "title": "{{.title}}",
              "body": "{{.body}}",
              "userId": 1
            }
          }
        }
      ]
    }
  ]
}
