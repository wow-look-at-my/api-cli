<?xml version="1.0" encoding="UTF-8"?>

<!--
	EXPERIMENT ONLY. Nothing loads this file. Exploring a declaration format
	for api-cli. No Go code, schema, or loader is wired to it.

	FORMATTING MODEL (this revision): there is NO <formats> registry, no named
	formats, no per-view <when>/<default>/<input>. Output is shaped
	AUTOMATICALLY from the response (PowerShell-style), and a command attaches a
	FOCUSED override only when the automatic choice isn't good enough.

	  Automatic (no config at all):
	    JSON array of objects  -> table   (columns = the objects' keys)
	    JSON object            -> list    (one "Label: value" line per field)
	    JSON array of scalars  -> lines   (one per line)
	    non-JSON / scalar      -> raw
	  So pr-diff (diff), readme (raw), and contents (dir array OR file object)
	  need NOTHING; the shape decides.

	  Focused overrides (attached to a command; inherit down the tree):
	    <table [over="data.items"] [footer="..."]>   like Format-Table
	      <column header="STARS">stargazers_count</column>
	      <column header="LANG" default="-">language</column>
	      <column header="SHA" truncate="7">sha</column>
	      <column header="%" expr='...'/>             computed column
	    <list>                                        like Format-List
	      <field label="Repo">full_name</field>
	      <field label="License" expr='...'/>         computed field
	    <template> ...nodes... </template>            escape hatch: a fully
	                                                  custom layout (headers,
	                                                  bodies, joins) for output a
	                                                  flat table/list can't do.
	  A runtime layer (not in this file) would mirror the PowerShell verbs:
	  `table` / `list` / `json` | `raw` flags to override per-invocation, the way
	  you'd pipe to Format-Table / Format-List / ConvertTo-Json / Out-String.

	  SCOPES: <column> bodies are relative to each row item (login, not
	  data.login); @key/@value are the entry when <table over=> walks a map
	  (rate, languages). <field> bodies are relative to the object. <template>
	  and footer= and expr= see the whole context (.data, .arg, .var, ...).
	  Placeholders (<value>/<if>/<for>) and the text/template expr= escape hatch
	  work as before.

	WEB REQUESTS are first-class (no curl/wget/shell). <run> holds a
	<request method="GET"> with <url>, <query from="entry.query"/> (or <param>s),
	<header> children (auth gated on var.token, resolved once in <vars>), and an
	optional <response jq="var.filter"/> to shape the JSON. Omit <response> for a
	raw body. The jq `filter` var stays CDATA (jq source, a foreign language).

	Whitespace: structural indentation is TABS; assume the loader strips the
	common leading tabs from <template> text. Column alignment in lists/templates
	uses SPACES, which survive that strip.
-->

<config
	name="github"
	schema="https://raw.githubusercontent.com/wow-look-at-my/api-cli/master/api.schema.json">

	<description>Comfortable read-only wrapper for the GitHub REST API. Aggressively strips noise from responses: *url fields, GraphQL node_ids, empty gravatar_ids, duplicate counts, reaction breakdowns, permission objects, and other metadata that bloats output without adding value. Set $GITHUB_TOKEN / $GH_TOKEN for authenticated access (60 req/hr unauthenticated, 5000/hr authenticated). Set $GITHUB_API_URL to target a GitHub Enterprise Server instance.</description>

	<vars>
		<var name="base_url"><value name="env.GITHUB_API_URL" default="https://api.github.com"/></var>
		<var name="ua">api-cli-github-example</var>
		<!-- Resolve the token once: whichever of GITHUB_TOKEN / GH_TOKEN is set.
		     Every request then just checks var.token, no per-request if/else. -->
		<var name="token"><value expr='{{ or .env.GITHUB_TOKEN .env.GH_TOKEN }}'/></var>
		<!-- jq filter shared by every command: recursively drop *url keys,
		     GraphQL node_ids, and other noise, then drop counts that duplicate
		     a *_count field. Opaque jq source, left verbatim. -->
		<var name="filter"><![CDATA[walk(if type == "object" then with_entries(select((.key | endswith("url") | not) and (.key | IN("node_id","gravatar_id","user_view_type","site_admin","performed_via_github_app","active_lock_reason","author_association","temp_clone_token","custom_properties","issue_field_values","permissions","_links","network_count","pinned_comment","reactions","sub_issues_summary","issue_dependencies_summary") | not))) | if has("forks_count") then del(.forks) else . end | if has("watchers_count") then del(.watchers) else . end | if has("open_issues_count") then del(.open_issues) else . end else . end)]]></var>
	</vars>

	<!-- Root request, inherited by every leaf. -->
	<run>
		<request method="GET">
			<url><value name="var.base_url"/><value name="entry.path"/></url>
			<query from="entry.query"/>
			<header name="User-Agent"><value name="var.ua"/></header>
			<header name="Accept">application/vnd.github+json</header>
			<header name="X-GitHub-Api-Version">2022-11-28</header>
			<if test="var.token">
				<header name="Authorization">Bearer <value name="var.token"/></header>
			</if>
			<response jq="var.filter"/>
		</request>
	</run>

	<command name="user" description="Read user info.">
		<command name="get" description="Fetch a user. Omit USERNAME to use /user (the authenticated viewer; requires a token).">
			<arg name="username" type="string" description="GitHub username."/>
			<list>
				<field label="Login">login</field>
				<field label="ID">id</field>
				<field label="Name" default="-">name</field>
				<field label="Company" default="-">company</field>
				<field label="Location" default="-">location</field>
				<field label="Bio" default="-">bio</field>
				<field label="Followers">followers</field>
				<field label="Following">following</field>
				<field label="Repos">public_repos</field>
				<field label="Created">created_at</field>
			</list>
			<entry>
				<path><if test="arg.username">/users/<value name="arg.username" as="urlpath"/><else/>/user</if></path>
			</entry>
		</command>
		<command name="repos" description="List a user's public repositories.">
			<arg name="username" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30" description="Items per page (max 100)."/>
			<flag name="page" short="p" type="int" default="1" description="Page number."/>
			<flag name="sort" type="string" default="updated" description="created|updated|pushed|full_name."/>
			<table>
				<column header="NAME">full_name</column>
				<column header="STARS">stargazers_count</column>
				<column header="FORKS">forks_count</column>
				<column header="LANG" default="-">language</column>
				<column header="DESCRIPTION" default="-">description</column>
			</table>
			<entry>
				<path>/users/<value name="arg.username" as="urlpath"/>/repos</path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="sort"><value name="flag.sort"/></param>
				</query>
			</entry>
		</command>
		<command name="orgs" description="List a user's public organization memberships.">
			<arg name="username" type="string" required="true"/>
			<table>
				<column header="LOGIN">login</column>
				<column header="ID">id</column>
				<column header="DESCRIPTION" default="-">description</column>
			</table>
			<entry>
				<path>/users/<value name="arg.username" as="urlpath"/>/orgs</path>
			</entry>
		</command>
	</command>

	<command name="repo" description="Read repository info.">
		<command name="get" description="Fetch a repository.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<list>
				<field label="Repo">full_name</field>
				<field label="Description" default="-">description</field>
				<field label="Language" default="-">language</field>
				<field label="Stars">stargazers_count</field>
				<field label="Forks">forks_count</field>
				<field label="Issues">open_issues_count</field>
				<field label="Default">default_branch</field>
				<field label="License" default="-" expr='{{ with .license }}{{ .spdx_id }}{{ end }}'/>
				<field label="Created">created_at</field>
				<field label="Updated">updated_at</field>
				<field label="Pushed">pushed_at</field>
				<field label="Archived">archived</field>
				<field label="Fork">fork</field>
				<field label="Private">private</field>
			</list>
			<entry>
				<path>/repos/<value name="arg.repo"/></path>
			</entry>
		</command>
		<command name="issues" description="List issues for a repository.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<flag name="state" type="string" default="open" description="open|closed|all."/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="labels" type="string" default="" description="Comma-separated label names."/>
			<table>
				<column header="#">#<value name="number"/></column>
				<column header="STATE">state</column>
				<column header="AUTHOR">user.login</column>
				<column header="TITLE">title</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/issues</path>
				<query>
					<param name="state"><value name="flag.state"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="labels"><value name="flag.labels"/></param>
				</query>
			</entry>
		</command>
		<command name="issue" description="Fetch a single issue.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<template>
#<value name="data.number"/> (<value name="data.state"/>): <value name="data.title"/>
Author:  <value name="data.user.login"/>
Created: <value name="data.created_at"/>
Updated: <value name="data.updated_at"/>
<if test="data.labels">Labels:  <for each="data.labels" join=", "><value name="name"/></for></if>
<value name="data.body" default=""/>
			</template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/issues/<value name="arg.number"/></path>
			</entry>
		</command>
		<command name="prs" description="List pull requests for a repository.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<flag name="state" type="string" default="open" description="open|closed|all."/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<table>
				<column header="#">#<value name="number"/></column>
				<column header="STATE">state</column>
				<column header="AUTHOR">user.login</column>
				<column header="TITLE">title</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/pulls</path>
				<query>
					<param name="state"><value name="flag.state"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
		<command name="pr" description="Fetch a single pull request: description, comment counts, and diff size.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<template>
#<value name="data.number"/> (<value name="data.state"/><if test="data.draft">, draft</if><if test="data.merged">, merged</if>): <value name="data.title"/>
Author:   <value name="data.user.login"/>
Branch:   <value name="data.head.ref"/> -> <value name="data.base.ref"/>
Created:  <value name="data.created_at"/>
Updated:  <value name="data.updated_at"/>
Comments: <value name="data.comments" default="0"/> conversation, <value name="data.review_comments" default="0"/> review
Commits:  <value name="data.commits" default="0"/>
Diff:     +<value name="data.additions" default="0"/> -<value name="data.deletions" default="0"/> across <value name="data.changed_files" default="0"/> file(s)
<if test="data.labels">Labels:   <for each="data.labels" join=", "><value name="name"/></for></if>
<value name="data.body" default=""/>
			</template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/pulls/<value name="arg.number"/></path>
			</entry>
		</command>
		<command name="pr-diff" description="Fetch the unified diff for a pull request.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<run>
				<request method="GET">
					<url><value name="var.base_url"/>/repos/<value name="arg.repo"/>/pulls/<value name="arg.number"/></url>
					<header name="User-Agent"><value name="var.ua"/></header>
					<header name="Accept">application/vnd.github.diff</header>
					<if test="var.token">
						<header name="Authorization">Bearer <value name="var.token"/></header>
					</if>
				</request>
			</run>
		</command>
		<command name="pr-comments" description="List a pull request's comments. Defaults to the conversation (issue) comments; pass --review for inline code-review comments.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<flag name="review" short="r" type="bool" default="false" description="List inline code-review comments instead of conversation comments."/>
			<flag name="limit" short="n" type="int" default="30" description="Items per page (max 100)."/>
			<flag name="page" short="p" type="int" default="1" description="Page number."/>
			<template><for each="data" empty="No comments.">@<value name="user.login"/><if test="path"> on <value name="path"/><if test="line">:<value name="line"/></if></if> (<value name="created_at"/>):
<value name="body"/>

</for></template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/<if test="flag.review">pulls/<value name="arg.number"/>/comments<else/>issues/<value name="arg.number"/>/comments</if></path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
		<command name="releases" description="List releases.">
			<arg name="repo" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<table>
				<column header="TAG">tag_name</column>
				<column header="NAME" default="-">name</column>
				<column header="PUBLISHED">published_at</column>
				<column header="DRAFT">draft</column>
				<column header="PRERELEASE">prerelease</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/releases</path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
		<command name="release" description="Fetch a release by tag, or `latest`.">
			<arg name="repo" type="string" required="true"/>
			<arg name="tag" type="string" required="true" description="Tag name, or `latest`."/>
			<template>
Tag:       <value name="data.tag_name"/>
Name:      <value name="data.name" default="-"/>
Published: <value name="data.published_at"/>
Author:    <value name="data.author.login"/>
Draft:     <value name="data.draft"/>    Prerelease: <value name="data.prerelease"/>

<value name="data.body" default=""/>
			</template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/releases/<if test="arg.tag" eq="latest">latest<else/>tags/<value name="arg.tag" as="urlpath"/></if></path>
			</entry>
		</command>
		<command name="commits" description="List recent commits.">
			<arg name="repo" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="branch" type="string" default="" description="Branch / SHA / tag to start from."/>
			<flag name="path" type="string" default="" description="Restrict to commits touching this path."/>
			<table>
				<column header="SHA" truncate="7">sha</column>
				<column header="AUTHOR">commit.author.name</column>
				<column header="DATE">commit.author.date</column>
				<column header="MESSAGE" firstline="true">commit.message</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/commits</path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="sha"><value name="flag.branch"/></param>
					<param name="path"><value name="flag.path"/></param>
				</query>
			</entry>
		</command>
		<command name="commit" description="Fetch a single commit.">
			<arg name="repo" type="string" required="true"/>
			<arg name="sha" type="string" required="true" description="Commit SHA, branch, or tag."/>
			<template>
SHA:     <value name="data.sha"/>
Author:  <value name="data.commit.author.name"/> &lt;<value name="data.commit.author.email"/>&gt;
Date:    <value name="data.commit.author.date"/>

<value name="data.commit.message"/>
			</template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/commits/<value name="arg.sha" as="urlpath"/></path>
			</entry>
		</command>
		<command name="branches" description="List branches.">
			<arg name="repo" type="string" required="true"/>
			<table>
				<column header="NAME">name</column>
				<column header="SHA" truncate="7">commit.sha</column>
				<column header="PROTECTED">protected</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/branches</path>
				<query>
					<param name="per_page">100</param>
				</query>
			</entry>
		</command>
		<command name="tags" description="List tags.">
			<arg name="repo" type="string" required="true"/>
			<table>
				<column header="NAME">name</column>
				<column header="SHA" truncate="7">commit.sha</column>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/tags</path>
				<query>
					<param name="per_page">100</param>
				</query>
			</entry>
		</command>
		<command name="contents" description="Fetch a file or directory listing. Omit PATH to list the repo root; otherwise a slash-delimited path (not URL-encoded). Auto-formats: a directory listing is an array (table), a single file is an object (list).">
			<arg name="repo" type="string" required="true"/>
			<arg name="path" type="string" description="File or directory path within the repo. Omit for the root listing."/>
			<flag name="ref" short="r" type="string" default="" description="Branch / SHA / tag."/>
			<entry>
				<path>/repos/<value name="arg.repo"/>/contents<if test="arg.path">/<value name="arg.path"/></if></path>
				<query>
					<param name="ref"><value name="flag.ref"/></param>
				</query>
			</entry>
		</command>
		<command name="readme" description="Fetch the rendered raw README.">
			<arg name="repo" type="string" required="true"/>
			<flag name="ref" short="r" type="string" default="" description="Branch / SHA / tag."/>
			<run>
				<request method="GET">
					<url><value name="var.base_url"/>/repos/<value name="arg.repo"/>/readme</url>
					<query>
						<if test="flag.ref"><param name="ref"><value name="flag.ref"/></param></if>
					</query>
					<header name="User-Agent"><value name="var.ua"/></header>
					<header name="Accept">application/vnd.github.raw</header>
					<if test="var.token">
						<header name="Authorization">Bearer <value name="var.token"/></header>
					</if>
				</request>
			</run>
		</command>
		<command name="languages" description="Map of languages to byte counts.">
			<arg name="repo" type="string" required="true"/>
			<!-- A map (language -> bytes). <table over="data"> walks it with
			     @key/@value; the "%" column is an aggregate (each row's share of
			     the summed total), so it uses the expr escape hatch: `.` is this
			     row's byte count, $.data is the whole map to total up. -->
			<table over="data">
				<column header="LANGUAGE">@key</column>
				<column header="BYTES">@value</column>
				<column header="%" expr='{{ $t := 0 }}{{ range $.data }}{{ $t = add $t . }}{{ end }}{{ printf "%.1f%%" (mulf 100.0 (divf . $t)) }}'/>
			</table>
			<entry>
				<path>/repos/<value name="arg.repo"/>/languages</path>
			</entry>
		</command>
		<command name="topics" description="List repository topics.">
			<arg name="repo" type="string" required="true"/>
			<!-- The response wraps the array in {names:[...]}, so drill into it
			     with a tiny template; a bare array would auto-format as lines. -->
			<template><for each="data.names"><value/>
</for></template>
			<entry>
				<path>/repos/<value name="arg.repo"/>/topics</path>
			</entry>
		</command>
	</command>

	<command name="org" description="Read organization info.">
		<command name="get" description="Fetch an org.">
			<arg name="org" type="string" required="true"/>
			<list>
				<field label="Login">login</field>
				<field label="ID">id</field>
				<field label="Name" default="-">name</field>
				<field label="Description" default="-">description</field>
				<field label="Location" default="-">location</field>
				<field label="Blog" default="-">blog</field>
				<field label="Members">followers</field>
				<field label="Repos">public_repos</field>
				<field label="Created">created_at</field>
			</list>
			<entry>
				<path>/orgs/<value name="arg.org" as="urlpath"/></path>
			</entry>
		</command>
		<command name="members" description="List public members.">
			<arg name="org" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<table>
				<column header="LOGIN">login</column>
				<column header="ID">id</column>
				<column header="TYPE">type</column>
			</table>
			<entry>
				<path>/orgs/<value name="arg.org" as="urlpath"/>/public_members</path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
		<command name="repos" description="List org repositories.">
			<arg name="org" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="type" type="string" default="all" description="all|public|private|forks|sources|member."/>
			<table>
				<column header="NAME">full_name</column>
				<column header="STARS">stargazers_count</column>
				<column header="FORKS">forks_count</column>
				<column header="LANG" default="-">language</column>
				<column header="DESCRIPTION" default="-">description</column>
			</table>
			<entry>
				<path>/orgs/<value name="arg.org" as="urlpath"/>/repos</path>
				<query>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="type"><value name="flag.type"/></param>
				</query>
			</entry>
		</command>
	</command>

	<command name="search" description="Search across GitHub.">
		<command name="repos" description="Search repositories. QUERY accepts the full GitHub search syntax (e.g. `language:go stars:>1000`).">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="sort" type="string" default="" description="stars|forks|updated|help-wanted-issues."/>
			<flag name="order" type="string" default="desc" description="asc|desc."/>
			<table over="data.items" footer="{{.data.total_count}} total">
				<column header="NAME">full_name</column>
				<column header="STARS">stargazers_count</column>
				<column header="LANG" default="-">language</column>
				<column header="DESCRIPTION" default="-">description</column>
			</table>
			<entry>
				<path>/search/repositories</path>
				<query>
					<param name="q"><value name="arg.query"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="sort"><value name="flag.sort"/></param>
					<param name="order"><value name="flag.order"/></param>
				</query>
			</entry>
		</command>
		<command name="code" description="Search code. Requires authentication.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<table over="data.items" footer="{{.data.total_count}} total">
				<column header="REPO">repository.full_name</column>
				<column header="PATH">path</column>
			</table>
			<entry>
				<path>/search/code</path>
				<query>
					<param name="q"><value name="arg.query"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
		<command name="issues" description="Search issues and pull requests.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="sort" type="string" default="" description="comments|reactions|created|updated."/>
			<vars>
				<var name="filter"><![CDATA[walk(if type == "object" then with_entries(select((.key == "repository_url" or (.key | endswith("url") | not)) and (.key | IN("node_id","gravatar_id","user_view_type","site_admin","performed_via_github_app","active_lock_reason","author_association","temp_clone_token","custom_properties","issue_field_values","permissions","_links","network_count","pinned_comment","reactions","sub_issues_summary","issue_dependencies_summary") | not))) | if has("forks_count") then del(.forks) else . end | if has("watchers_count") then del(.watchers) else . end | if has("open_issues_count") then del(.open_issues) else . end else . end)]]></var>
			</vars>
			<table over="data.items" footer="{{.data.total_count}} total">
				<column header="REPO" expr='{{ .repository_url | default "" | trimPrefix (printf "%s/repos/" $.var.base_url) }}'/>
				<column header="#">#<value name="number"/></column>
				<column header="STATE">state</column>
				<column header="TITLE">title</column>
			</table>
			<entry>
				<path>/search/issues</path>
				<query>
					<param name="q"><value name="arg.query"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
					<param name="sort"><value name="flag.sort"/></param>
				</query>
			</entry>
		</command>
		<command name="users" description="Search users.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<table over="data.items" footer="{{.data.total_count}} total">
				<column header="LOGIN">login</column>
				<column header="ID">id</column>
				<column header="TYPE">type</column>
			</table>
			<entry>
				<path>/search/users</path>
				<query>
					<param name="q"><value name="arg.query"/></param>
					<param name="per_page"><value name="flag.limit"/></param>
					<param name="page"><value name="flag.page"/></param>
				</query>
			</entry>
		</command>
	</command>

	<command name="rate-limit" description="Show the current rate-limit status. (RESET column is unix epoch seconds.)">
		<table over="data.resources">
			<column header="RESOURCE">@key</column>
			<column header="LIMIT">limit</column>
			<column header="REMAINING">remaining</column>
			<column header="RESET">reset</column>
		</table>
		<entry>
			<path>/rate_limit</path>
		</entry>
	</command>

</config>
