<?xml version="1.0" encoding="UTF-8"?>

<!--
	EXPERIMENT ONLY. Nothing loads this file. It is a hand-translation of
	samples/github/github.yaml into XML so we can eyeball whether an XML
	declaration format reads better than the tab-YAML. No Go code, schema,
	or loader is wired to it.

	Element / attribute conventions used here (one possible mapping):

	  <config name= schema=>      top-level config; long prose -> <description>
	  <var name=>...              one entry of the `vars` map (text = value)
	  <run>...</run>             the executable `command` template (shell form).
	                              Lives on <config> (root, inherited) or inside a
	                              <command> to override for that subtree.
	  <command name= description= format=>
	                              a node in the CLI tree. Nest <command> for
	                              subcommands; no <commands> wrapper needed.
	                              `format=` is a named-format reference; for an
	                              inline format, nest a <format> instead.
	  <arg .../> <flag .../>      positional args / named flags (attrs mirror
	                              the struct fields: name/type/required/short/
	                              default/description).
	  <entry path=>               + <query><param name= value=/></query>
	  <formats> <format name= input=> <view name= when= default=>BODY</view>
	                              the reusable format registry and its views.

	Whitespace note: <run> and <view> bodies are wrapped in CDATA so the
	quote/brace/pipe/backslash-t/<> soup needs zero escaping. Inner
	indentation here is purely for reading; assume a block-scalar-style
	dedent+trim (same as the YAML loader gives) would apply.
-->

<config
	name="github"
	schema="https://raw.githubusercontent.com/wow-look-at-my/api-cli/master/api.schema.json">

	<description>Comfortable read-only wrapper for the GitHub REST API. Aggressively strips noise from responses: *url fields, GraphQL node_ids, empty gravatar_ids, duplicate counts, reaction breakdowns, permission objects, and other metadata that bloats output without adding value. Set $GITHUB_TOKEN / $GH_TOKEN for authenticated access (60 req/hr unauthenticated, 5000/hr authenticated). Set $GITHUB_API_URL to target a GitHub Enterprise Server instance.</description>

	<vars>
		<var name="base_url">{{.env.GITHUB_API_URL | default "https://api.github.com"}}</var>
		<var name="ua">api-cli-github-example</var>
		<!-- jq filter shared by every command: recursively drop *url keys,
		     GraphQL node_ids, and other noise, then drop counts that
		     duplicate a *_count field. -->
		<var name="filter"><![CDATA[walk(if type == "object" then with_entries(select((.key | endswith("url") | not) and (.key | IN("node_id","gravatar_id","user_view_type","site_admin","performed_via_github_app","active_lock_reason","author_association","temp_clone_token","custom_properties","issue_field_values","permissions","_links","network_count","pinned_comment","reactions","sub_issues_summary","issue_dependencies_summary") | not))) | if has("forks_count") then del(.forks) else . end | if has("watchers_count") then del(.watchers) else . end | if has("open_issues_count") then del(.open_issues) else . end else . end)]]></var>
	</vars>

	<!-- Root command, inherited by every leaf. -->
	<run><![CDATA[curl -fsSL -H {{shellquote (printf "User-Agent: %s" .var.ua)}} -H 'Accept: application/vnd.github+json' -H 'X-GitHub-Api-Version: 2022-11-28'{{if .env.GITHUB_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GITHUB_TOKEN)}}{{else if .env.GH_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GH_TOKEN)}}{{end}} {{shellquote (printf "%s%s%s" .var.base_url .entry.path (querystring .entry.query))}} | jq {{shellquote .var.filter}}]]></run>

	<formats>
		<format name="user" input="json">
			<view name="table" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "LOGIN\tID\tTYPE" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v" .login .id .type) }}{{ end }}{{ tabwriter $rows }}]]></view>
			<view name="detail" default="true"><![CDATA[
Login:     {{.data.login}}
ID:        {{.data.id}}
Name:      {{default "-" .data.name}}
Company:   {{default "-" .data.company}}
Location:  {{default "-" .data.location}}
Bio:       {{default "-" .data.bio}}
Followers: {{.data.followers}}    Following: {{.data.following}}    Repos: {{.data.public_repos}}
Created:   {{.data.created_at}}
]]></view>
		</format>

		<format name="repo" input="json">
			<view name="table" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "NAME\tSTARS\tFORKS\tLANG\tDESCRIPTION" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v\t%v\t%v" .full_name .stargazers_count .forks_count (default "-" .language) (default "" .description)) }}{{ end }}{{ tabwriter $rows }}]]></view>
			<view name="detail" default="true"><![CDATA[
Repo:        {{.data.full_name}}
Description: {{default "-" .data.description}}
Language:    {{default "-" .data.language}}
Stars:       {{.data.stargazers_count}}
Forks:       {{.data.forks_count}}
Issues:      {{.data.open_issues_count}}
Default:     {{.data.default_branch}}
License:     {{if .data.license}}{{.data.license.spdx_id}}{{else}}-{{end}}
Created:     {{.data.created_at}}
Updated:     {{.data.updated_at}}
Pushed:      {{.data.pushed_at}}
Archived:    {{.data.archived}}    Fork: {{.data.fork}}    Private: {{.data.private}}
]]></view>
		</format>

		<format name="issue" input="json">
			<view name="table" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "#\tSTATE\tAUTHOR\tTITLE" }}{{ range .data }}{{ $rows = append $rows (printf "#%v\t%v\t%v\t%v" .number .state .user.login .title) }}{{ end }}{{ tabwriter $rows }}]]></view>
			<view name="detail" default="true"><![CDATA[
#{{.data.number}} ({{.data.state}}): {{.data.title}}
Author:  {{.data.user.login}}
Created: {{.data.created_at}}
Updated: {{.data.updated_at}}
{{if .data.labels}}Labels:  {{range $i, $l := .data.labels}}{{if $i}}, {{end}}{{$l.name}}{{end}}
{{end}}
{{default "" .data.body}}
]]></view>
		</format>

		<format name="pr" input="json">
			<view name="detail" default="true"><![CDATA[
#{{.data.number}} ({{.data.state}}{{if .data.draft}}, draft{{end}}{{if .data.merged}}, merged{{end}}): {{.data.title}}
Author:   {{.data.user.login}}
Branch:   {{.data.head.ref}} -> {{.data.base.ref}}
Created:  {{.data.created_at}}
Updated:  {{.data.updated_at}}
Comments: {{default 0 .data.comments}} conversation, {{default 0 .data.review_comments}} review
Commits:  {{default 0 .data.commits}}
Diff:     +{{default 0 .data.additions}} -{{default 0 .data.deletions}} across {{default 0 .data.changed_files}} file(s)
{{if .data.labels}}Labels:   {{range $i, $l := .data.labels}}{{if $i}}, {{end}}{{$l.name}}{{end}}
{{end}}
{{default "" .data.body}}
]]></view>
		</format>

		<format name="comment" input="json">
			<view name="list" default="true"><![CDATA[{{if .data}}{{range .data}}@{{.user.login}}{{if .path}} on {{.path}}{{with .line}}:{{.}}{{end}}{{end}} ({{.created_at}}):
{{.body}}

{{end}}{{else}}No comments.
{{end}}]]></view>
		</format>

		<format name="release" input="json">
			<view name="table" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "TAG\tNAME\tPUBLISHED\tDRAFT\tPRERELEASE" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v\t%v\t%v" .tag_name (default "-" .name) .published_at .draft .prerelease) }}{{ end }}{{ tabwriter $rows }}]]></view>
			<view name="detail" default="true"><![CDATA[
Tag:       {{.data.tag_name}}
Name:      {{default "-" .data.name}}
Published: {{.data.published_at}}
Author:    {{.data.author.login}}
Draft:     {{.data.draft}}    Prerelease: {{.data.prerelease}}

{{default "" .data.body}}
]]></view>
		</format>

		<format name="commit" input="json">
			<view name="table" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "SHA\tAUTHOR\tDATE\tMESSAGE" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v\t%v" (substr 0 7 .sha) .commit.author.name .commit.author.date (regexReplaceAll "\n.*" .commit.message "")) }}{{ end }}{{ tabwriter $rows }}]]></view>
			<view name="detail" default="true"><![CDATA[
SHA:     {{.data.sha}}
Author:  {{.data.commit.author.name}} <{{.data.commit.author.email}}>
Date:    {{.data.commit.author.date}}

{{.data.commit.message}}
]]></view>
		</format>

		<format name="branch" input="json">
			<view name="table" default="true" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "NAME\tSHA\tPROTECTED" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v" .name (substr 0 7 .commit.sha) .protected) }}{{ end }}{{ tabwriter $rows }}]]></view>
		</format>

		<format name="tag" input="json">
			<view name="table" default="true" when='{{ kindIs "slice" .data }}'><![CDATA[{{ $rows := list "NAME\tSHA" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v" .name (substr 0 7 .commit.sha)) }}{{ end }}{{ tabwriter $rows }}]]></view>
		</format>

		<format name="rate" input="json">
			<view name="table" default="true"><![CDATA[{{ $rows := list "RESOURCE\tLIMIT\tREMAINING\tRESET" }}{{ range $k, $v := .data.resources }}{{ $rows = append $rows (printf "%v\t%v\t%v\t%v" $k $v.limit $v.remaining $v.reset) }}{{ end }}{{ tabwriter $rows }}]]></view>
		</format>

		<format name="raw" input="raw">
			<view name="raw" default="true"><![CDATA[
{{ .data }}
]]></view>
		</format>
	</formats>

	<command name="user" description="Read user info." format="user">
		<command name="get" description="Fetch a user. Omit USERNAME to use /user (the authenticated viewer; requires a token).">
			<arg name="username" type="string" description="GitHub username."/>
			<entry path="{{if .arg.username}}/users/{{urlpath .arg.username}}{{else}}/user{{end}}"/>
		</command>
		<command name="repos" description="List a user's public repositories." format="repo">
			<arg name="username" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30" description="Items per page (max 100)."/>
			<flag name="page" short="p" type="int" default="1" description="Page number."/>
			<flag name="sort" type="string" default="updated" description="created|updated|pushed|full_name."/>
			<entry path="/users/{{urlpath .arg.username}}/repos">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="sort" value="{{.flag.sort}}"/>
				</query>
			</entry>
		</command>
		<command name="orgs" description="List a user's public organization memberships.">
			<arg name="username" type="string" required="true"/>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $rows := list "LOGIN\tID\tDESCRIPTION" }}{{ range .data }}{{ $rows = append $rows (printf "%v\t%v\t%v" .login .id (default "" .description)) }}{{ end }}{{ tabwriter $rows }}]]></view>
			</format>
			<entry path="/users/{{urlpath .arg.username}}/orgs"/>
		</command>
	</command>

	<command name="repo" description="Read repository info." format="repo">
		<command name="get" description="Fetch a repository.">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<entry path="/repos/{{.arg.repo}}"/>
		</command>
		<command name="issues" description="List issues for a repository." format="issue">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<flag name="state" type="string" default="open" description="open|closed|all."/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="labels" type="string" default="" description="Comma-separated label names."/>
			<entry path="/repos/{{.arg.repo}}/issues">
				<query>
					<param name="state" value="{{.flag.state}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="labels" value="{{.flag.labels}}"/>
				</query>
			</entry>
		</command>
		<command name="issue" description="Fetch a single issue." format="issue">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<entry path="/repos/{{.arg.repo}}/issues/{{.arg.number}}"/>
		</command>
		<command name="prs" description="List pull requests for a repository." format="issue">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<flag name="state" type="string" default="open" description="open|closed|all."/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<entry path="/repos/{{.arg.repo}}/pulls">
				<query>
					<param name="state" value="{{.flag.state}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
		<command name="pr" description="Fetch a single pull request: description, comment counts, and diff size." format="pr">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<entry path="/repos/{{.arg.repo}}/pulls/{{.arg.number}}"/>
		</command>
		<command name="pr-diff" description="Fetch the unified diff for a pull request." format="raw">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<run><![CDATA[curl -fsSL -H {{shellquote (printf "User-Agent: %s" .var.ua)}} -H 'Accept: application/vnd.github.diff'{{if .env.GITHUB_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GITHUB_TOKEN)}}{{else if .env.GH_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GH_TOKEN)}}{{end}} {{shellquote (printf "%s/repos/%s/pulls/%v" .var.base_url .arg.repo .arg.number)}}]]></run>
		</command>
		<command name="pr-comments" description="List a pull request's comments. Defaults to the conversation (issue) comments; pass --review for inline code-review comments." format="comment">
			<arg name="repo" type="string" required="true" description="owner/name."/>
			<arg name="number" type="int" required="true"/>
			<flag name="review" short="r" type="bool" default="false" description="List inline code-review comments instead of conversation comments."/>
			<flag name="limit" short="n" type="int" default="30" description="Items per page (max 100)."/>
			<flag name="page" short="p" type="int" default="1" description="Page number."/>
			<entry path="/repos/{{.arg.repo}}/{{if .flag.review}}pulls/{{.arg.number}}/comments{{else}}issues/{{.arg.number}}/comments{{end}}">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
		<command name="releases" description="List releases." format="release">
			<arg name="repo" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<entry path="/repos/{{.arg.repo}}/releases">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
		<command name="release" description="Fetch a release by tag, or `latest`." format="release">
			<arg name="repo" type="string" required="true"/>
			<arg name="tag" type="string" required="true" description="Tag name, or `latest`."/>
			<entry path='/repos/{{.arg.repo}}/releases/{{if eq .arg.tag "latest"}}latest{{else}}tags/{{urlpath .arg.tag}}{{end}}'/>
		</command>
		<command name="commits" description="List recent commits." format="commit">
			<arg name="repo" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="branch" type="string" default="" description="Branch / SHA / tag to start from."/>
			<flag name="path" type="string" default="" description="Restrict to commits touching this path."/>
			<entry path="/repos/{{.arg.repo}}/commits">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="sha" value="{{.flag.branch}}"/>
					<param name="path" value="{{.flag.path}}"/>
				</query>
			</entry>
		</command>
		<command name="commit" description="Fetch a single commit." format="commit">
			<arg name="repo" type="string" required="true"/>
			<arg name="sha" type="string" required="true" description="Commit SHA, branch, or tag."/>
			<entry path="/repos/{{.arg.repo}}/commits/{{urlpath .arg.sha}}"/>
		</command>
		<command name="branches" description="List branches." format="branch">
			<arg name="repo" type="string" required="true"/>
			<entry path="/repos/{{.arg.repo}}/branches">
				<query>
					<param name="per_page" value="100"/>
				</query>
			</entry>
		</command>
		<command name="tags" description="List tags." format="tag">
			<arg name="repo" type="string" required="true"/>
			<entry path="/repos/{{.arg.repo}}/tags">
				<query>
					<param name="per_page" value="100"/>
				</query>
			</entry>
		</command>
		<command name="contents" description="Fetch a file or directory listing. Omit PATH to list the repo root; otherwise a slash-delimited path (not URL-encoded).">
			<arg name="repo" type="string" required="true"/>
			<arg name="path" type="string" description="File or directory path within the repo. Omit for the root listing."/>
			<flag name="ref" short="r" type="string" default="" description="Branch / SHA / tag."/>
			<entry path="/repos/{{.arg.repo}}/contents{{if .arg.path}}/{{.arg.path}}{{end}}">
				<query>
					<param name="ref" value="{{.flag.ref}}"/>
				</query>
			</entry>
		</command>
		<command name="readme" description="Fetch the rendered raw README." format="raw">
			<arg name="repo" type="string" required="true"/>
			<flag name="ref" short="r" type="string" default="" description="Branch / SHA / tag."/>
			<run><![CDATA[curl -fsSL -H {{shellquote (printf "User-Agent: %s" .var.ua)}} -H 'Accept: application/vnd.github.raw'{{if .env.GITHUB_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GITHUB_TOKEN)}}{{else if .env.GH_TOKEN}} -H {{shellquote (printf "Authorization: Bearer %s" .env.GH_TOKEN)}}{{end}} {{if .flag.ref}}{{shellquote (printf "%s/repos/%s/readme?ref=%s" .var.base_url .arg.repo (urlpath .flag.ref))}}{{else}}{{shellquote (printf "%s/repos/%s/readme" .var.base_url .arg.repo)}}{{end}}]]></run>
		</command>
		<command name="languages" description="Map of languages to byte counts.">
			<arg name="repo" type="string" required="true"/>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $total := 0 }}{{ range $_, $b := .data }}{{ $total = add $total $b }}{{ end }}{{ $rows := list "LANGUAGE\tBYTES\t%" }}{{ range $lang, $bytes := .data }}{{ $rows = append $rows (printf "%v\t%v\t%.1f%%" $lang $bytes (mulf 100.0 (divf $bytes $total))) }}{{ end }}{{ tabwriter $rows }}]]></view>
			</format>
			<entry path="/repos/{{.arg.repo}}/languages"/>
		</command>
		<command name="topics" description="List repository topics.">
			<arg name="repo" type="string" required="true"/>
			<format input="json">
				<view name="list" default="true"><![CDATA[{{ range .data.names }}{{ . }}
{{ end }}]]></view>
			</format>
			<entry path="/repos/{{.arg.repo}}/topics"/>
		</command>
	</command>

	<command name="org" description="Read organization info.">
		<command name="get" description="Fetch an org.">
			<arg name="org" type="string" required="true"/>
			<format input="json">
				<view name="detail" default="true"><![CDATA[
Login:       {{.data.login}}
ID:          {{.data.id}}
Name:        {{default "-" .data.name}}
Description: {{default "-" .data.description}}
Location:    {{default "-" .data.location}}
Blog:        {{default "-" .data.blog}}
Members:     {{default 0 .data.followers}}    Repos: {{.data.public_repos}}
Created:     {{.data.created_at}}
]]></view>
			</format>
			<entry path="/orgs/{{urlpath .arg.org}}"/>
		</command>
		<command name="members" description="List public members." format="user">
			<arg name="org" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<entry path="/orgs/{{urlpath .arg.org}}/public_members">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
		<command name="repos" description="List org repositories." format="repo">
			<arg name="org" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="type" type="string" default="all" description="all|public|private|forks|sources|member."/>
			<entry path="/orgs/{{urlpath .arg.org}}/repos">
				<query>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="type" value="{{.flag.type}}"/>
				</query>
			</entry>
		</command>
	</command>

	<command name="search" description="Search across GitHub.">
		<command name="repos" description="Search repositories. QUERY accepts the full GitHub search syntax (e.g. `language:go stars:>1000`).">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="sort" type="string" default="" description="stars|forks|updated|help-wanted-issues."/>
			<flag name="order" type="string" default="desc" description="asc|desc."/>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $rows := list "NAME\tSTARS\tLANG\tDESCRIPTION" }}{{ range .data.items }}{{ $rows = append $rows (printf "%v\t%v\t%v\t%v" .full_name .stargazers_count (default "-" .language) (default "" .description)) }}{{ end }}{{ tabwriter $rows }}
{{.data.total_count}} total]]></view>
			</format>
			<entry path="/search/repositories">
				<query>
					<param name="q" value="{{.arg.query}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="sort" value="{{.flag.sort}}"/>
					<param name="order" value="{{.flag.order}}"/>
				</query>
			</entry>
		</command>
		<command name="code" description="Search code. Requires authentication.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $rows := list "REPO\tPATH" }}{{ range .data.items }}{{ $rows = append $rows (printf "%v\t%v" .repository.full_name .path) }}{{ end }}{{ tabwriter $rows }}
{{.data.total_count}} total]]></view>
			</format>
			<entry path="/search/code">
				<query>
					<param name="q" value="{{.arg.query}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
		<command name="issues" description="Search issues and pull requests.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<flag name="sort" type="string" default="" description="comments|reactions|created|updated."/>
			<vars>
				<var name="filter"><![CDATA[walk(if type == "object" then with_entries(select((.key == "repository_url" or (.key | endswith("url") | not)) and (.key | IN("node_id","gravatar_id","user_view_type","site_admin","performed_via_github_app","active_lock_reason","author_association","temp_clone_token","custom_properties","issue_field_values","permissions","_links","network_count","pinned_comment","reactions","sub_issues_summary","issue_dependencies_summary") | not))) | if has("forks_count") then del(.forks) else . end | if has("watchers_count") then del(.watchers) else . end | if has("open_issues_count") then del(.open_issues) else . end else . end)]]></var>
			</vars>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $base := printf "%s/repos/" .var.base_url }}{{ $rows := list "REPO\t#\tSTATE\tTITLE" }}{{ range .data.items }}{{ $rows = append $rows (printf "%v\t#%v\t%v\t%v" (default "" .repository_url | trimPrefix $base) .number .state .title) }}{{ end }}{{ tabwriter $rows }}
{{.data.total_count}} total]]></view>
			</format>
			<entry path="/search/issues">
				<query>
					<param name="q" value="{{.arg.query}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
					<param name="sort" value="{{.flag.sort}}"/>
				</query>
			</entry>
		</command>
		<command name="users" description="Search users.">
			<arg name="query" type="string" required="true"/>
			<flag name="limit" short="n" type="int" default="30"/>
			<flag name="page" short="p" type="int" default="1"/>
			<format input="json">
				<view name="table" default="true"><![CDATA[{{ $rows := list "LOGIN\tID\tTYPE" }}{{ range .data.items }}{{ $rows = append $rows (printf "%v\t%v\t%v" .login .id .type) }}{{ end }}{{ tabwriter $rows }}
{{.data.total_count}} total]]></view>
			</format>
			<entry path="/search/users">
				<query>
					<param name="q" value="{{.arg.query}}"/>
					<param name="per_page" value="{{.flag.limit}}"/>
					<param name="page" value="{{.flag.page}}"/>
				</query>
			</entry>
		</command>
	</command>

	<command name="rate-limit" description="Show the current rate-limit status. (RESET column is unix epoch seconds.)" format="rate">
		<entry path="/rate_limit"/>
	</command>

</config>
