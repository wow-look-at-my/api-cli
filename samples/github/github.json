{
  "$schema": "https://raw.githubusercontent.com/wow-look-at-my/api-cli/master/api.schema.json",
  "name": "github",
  "description": "Comfortable read-only wrapper for the GitHub REST API. Aggressively strips noise from responses: *url fields, GraphQL node_ids, empty gravatar_ids, duplicate counts, reaction breakdowns, permission objects, and other metadata that bloats output without adding value. Set $GITHUB_TOKEN / $GH_TOKEN for authenticated access (60 req/hr unauthenticated, 5000/hr authenticated). Set $GITHUB_API_URL to target a GitHub Enterprise Server instance.",

  "vars": {
    "base_url": "{{.env.GITHUB_API_URL | default \"https://api.github.com\"}}",
    "ua": "api-cli-github-example",
    "filter": "walk(if type == \"object\" then with_entries(select((.key | endswith(\"url\") | not) and (.key | IN(\"node_id\",\"gravatar_id\",\"user_view_type\",\"site_admin\",\"performed_via_github_app\",\"active_lock_reason\",\"author_association\",\"temp_clone_token\",\"custom_properties\",\"issue_field_values\",\"permissions\",\"network_count\",\"pinned_comment\",\"reactions\",\"sub_issues_summary\",\"issue_dependencies_summary\") | not))) | if has(\"forks_count\") then del(.forks) else . end | if has(\"watchers_count\") then del(.watchers) else . end | if has(\"open_issues_count\") then del(.open_issues) else . end else . end)"
  },

  "command": "curl -fsSL -H {{shellquote (printf \"User-Agent: %s\" .var.ua)}} -H 'Accept: application/vnd.github+json' -H 'X-GitHub-Api-Version: 2022-11-28'{{if .env.GITHUB_TOKEN}} -H {{shellquote (printf \"Authorization: Bearer %s\" .env.GITHUB_TOKEN)}}{{else if .env.GH_TOKEN}} -H {{shellquote (printf \"Authorization: Bearer %s\" .env.GH_TOKEN)}}{{end}} {{shellquote (printf \"%s%s%s\" .var.base_url .entry.path (querystring .entry.query))}} | jq {{shellquote .var.filter}}",

  "formats": {
    "user": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"LOGIN\\tID\\tTYPE\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\" .login .id .type) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "Login:     {{.data.login}}\nID:        {{.data.id}}\nName:      {{default \"-\" .data.name}}\nCompany:   {{default \"-\" .data.company}}\nLocation:  {{default \"-\" .data.location}}\nBio:       {{default \"-\" .data.bio}}\nFollowers: {{.data.followers}}    Following: {{.data.following}}    Repos: {{.data.public_repos}}\nCreated:   {{.data.created_at}}\n"
        }
      ]
    },

    "repo": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"NAME\\tSTARS\\tFORKS\\tLANG\\tDESCRIPTION\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\\t%v\" .full_name .stargazers_count .forks_count (default \"-\" .language) (default \"\" .description)) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "Repo:        {{.data.full_name}}\nDescription: {{default \"-\" .data.description}}\nLanguage:    {{default \"-\" .data.language}}\nStars:       {{.data.stargazers_count}}\nForks:       {{.data.forks_count}}\nIssues:      {{.data.open_issues_count}}\nDefault:     {{.data.default_branch}}\nLicense:     {{if .data.license}}{{.data.license.spdx_id}}{{else}}-{{end}}\nCreated:     {{.data.created_at}}\nUpdated:     {{.data.updated_at}}\nPushed:      {{.data.pushed_at}}\nArchived:    {{.data.archived}}    Fork: {{.data.fork}}    Private: {{.data.private}}\n"
        }
      ]
    },

    "issue": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"#\\tSTATE\\tAUTHOR\\tTITLE\" }}{{ range .data }}{{ $rows = append $rows (printf \"#%v\\t%v\\t%v\\t%v\" .number .state .user.login .title) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "#{{.data.number}} ({{.data.state}}): {{.data.title}}\nAuthor:  {{.data.user.login}}\nCreated: {{.data.created_at}}\nUpdated: {{.data.updated_at}}\n{{if .data.labels}}Labels:  {{range $i, $l := .data.labels}}{{if $i}}, {{end}}{{$l.name}}{{end}}\n{{end}}\n{{default \"\" .data.body}}\n"
        }
      ]
    },

    "release": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"TAG\\tNAME\\tPUBLISHED\\tDRAFT\\tPRERELEASE\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\\t%v\" .tag_name (default \"-\" .name) .published_at .draft .prerelease) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "Tag:       {{.data.tag_name}}\nName:      {{default \"-\" .data.name}}\nPublished: {{.data.published_at}}\nAuthor:    {{.data.author.login}}\nDraft:     {{.data.draft}}    Prerelease: {{.data.prerelease}}\n\n{{default \"\" .data.body}}\n"
        }
      ]
    },

    "commit": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"SHA\\tAUTHOR\\tDATE\\tMESSAGE\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\" (substr 0 7 .sha) .commit.author.name .commit.author.date (regexReplaceAll \"\\n.*\" .commit.message \"\")) }}{{ end }}{{ tabwriter $rows }}"
        },
        {
          "name": "detail",
          "default": true,
          "template": "SHA:     {{.data.sha}}\nAuthor:  {{.data.commit.author.name}} <{{.data.commit.author.email}}>\nDate:    {{.data.commit.author.date}}\n\n{{.data.commit.message}}\n"
        }
      ]
    },

    "branch": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "default": true,
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"NAME\\tSHA\\tPROTECTED\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\" .name (substr 0 7 .commit.sha) .protected) }}{{ end }}{{ tabwriter $rows }}"
        }
      ]
    },

    "tag": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "default": true,
          "when": "{{ kindIs \"slice\" .data }}",
          "template": "{{ $rows := list \"NAME\\tSHA\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\" .name (substr 0 7 .commit.sha)) }}{{ end }}{{ tabwriter $rows }}"
        }
      ]
    },

    "rate": {
      "input": "json",
      "views": [
        {
          "name": "table",
          "default": true,
          "template": "{{ $rows := list \"RESOURCE\\tLIMIT\\tREMAINING\\tRESET\" }}{{ range $k, $v := .data.resources }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\" $k $v.limit $v.remaining $v.reset) }}{{ end }}{{ tabwriter $rows }}"
        }
      ]
    }
  },

  "commands": [
    {
      "name": "user",
      "description": "Read user info.",
      "format": "user",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a user. Omit USERNAME to use /user (the authenticated viewer; requires a token).",
          "args": [
            { "name": "username", "type": "string", "description": "GitHub username." }
          ],
          "entry": {
            "path": "{{if .arg.username}}/users/{{urlpath .arg.username}}{{else}}/user{{end}}"
          }
        },
        {
          "name": "repos",
          "description": "List a user's public repositories.",
          "args": [
            { "name": "username", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30, "description": "Items per page (max 100)." },
            { "name": "page", "short": "p", "type": "int", "default": 1, "description": "Page number." },
            { "name": "sort", "type": "string", "default": "updated", "description": "created|updated|pushed|full_name." }
          ],
          "format": "repo",
          "entry": {
            "path": "/users/{{urlpath .arg.username}}/repos",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}"
            }
          }
        },
        {
          "name": "orgs",
          "description": "List a user's public organization memberships.",
          "args": [
            { "name": "username", "type": "string", "required": true }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $rows := list \"LOGIN\\tID\\tDESCRIPTION\" }}{{ range .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\" .login .id (default \"\" .description)) }}{{ end }}{{ tabwriter $rows }}"
              }
            ]
          },
          "entry": {
            "path": "/users/{{urlpath .arg.username}}/orgs"
          }
        }
      ]
    },

    {
      "name": "repo",
      "description": "Read repository info.",
      "format": "repo",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}"
          }
        },
        {
          "name": "issues",
          "description": "List issues for a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "flags": [
            { "name": "state", "type": "string", "default": "open", "description": "open|closed|all." },
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "labels", "type": "string", "default": "", "description": "Comma-separated label names." }
          ],
          "format": "issue",
          "entry": {
            "path": "/repos/{{.arg.repo}}/issues",
            "query": {
              "state": "{{.flag.state}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "labels": "{{.flag.labels}}"
            }
          }
        },
        {
          "name": "issue",
          "description": "Fetch a single issue.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "format": "issue",
          "entry": {
            "path": "/repos/{{.arg.repo}}/issues/{{.arg.number}}"
          }
        },
        {
          "name": "prs",
          "description": "List pull requests for a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "flags": [
            { "name": "state", "type": "string", "default": "open", "description": "open|closed|all." },
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "format": "issue",
          "entry": {
            "path": "/repos/{{.arg.repo}}/pulls",
            "query": {
              "state": "{{.flag.state}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "pr",
          "description": "Fetch a single pull request.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "format": "issue",
          "entry": {
            "path": "/repos/{{.arg.repo}}/pulls/{{.arg.number}}"
          }
        },
        {
          "name": "releases",
          "description": "List releases.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "format": "release",
          "entry": {
            "path": "/repos/{{.arg.repo}}/releases",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "release",
          "description": "Fetch a release by tag, or `latest`.",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "tag", "type": "string", "required": true, "description": "Tag name, or `latest`." }
          ],
          "format": "release",
          "entry": {
            "path": "/repos/{{.arg.repo}}/releases/{{if eq .arg.tag \"latest\"}}latest{{else}}tags/{{urlpath .arg.tag}}{{end}}"
          }
        },
        {
          "name": "commits",
          "description": "List recent commits.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "branch", "type": "string", "default": "", "description": "Branch / SHA / tag to start from." },
            { "name": "path", "type": "string", "default": "", "description": "Restrict to commits touching this path." }
          ],
          "format": "commit",
          "entry": {
            "path": "/repos/{{.arg.repo}}/commits",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sha": "{{.flag.branch}}",
              "path": "{{.flag.path}}"
            }
          }
        },
        {
          "name": "commit",
          "description": "Fetch a single commit.",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "sha", "type": "string", "required": true, "description": "Commit SHA, branch, or tag." }
          ],
          "format": "commit",
          "entry": {
            "path": "/repos/{{.arg.repo}}/commits/{{urlpath .arg.sha}}"
          }
        },
        {
          "name": "branches",
          "description": "List branches.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "format": "branch",
          "entry": {
            "path": "/repos/{{.arg.repo}}/branches",
            "query": { "per_page": "100" }
          }
        },
        {
          "name": "tags",
          "description": "List tags.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "format": "tag",
          "entry": {
            "path": "/repos/{{.arg.repo}}/tags",
            "query": { "per_page": "100" }
          }
        },
        {
          "name": "contents",
          "description": "Fetch a file or directory listing. Omit PATH to list the repo root; otherwise a slash-delimited path (not URL-encoded).",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "path", "type": "string", "description": "File or directory path within the repo. Omit for the root listing." }
          ],
          "flags": [
            { "name": "ref", "short": "r", "type": "string", "default": "", "description": "Branch / SHA / tag." }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/contents{{if .arg.path}}/{{.arg.path}}{{end}}",
            "query": { "ref": "{{.flag.ref}}" }
          }
        },
        {
          "name": "readme",
          "description": "Fetch the rendered raw README.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "ref", "short": "r", "type": "string", "default": "", "description": "Branch / SHA / tag." }
          ],
          "command": "curl -fsSL -H {{shellquote (printf \"User-Agent: %s\" .var.ua)}} -H 'Accept: application/vnd.github.raw'{{if .env.GITHUB_TOKEN}} -H {{shellquote (printf \"Authorization: Bearer %s\" .env.GITHUB_TOKEN)}}{{else if .env.GH_TOKEN}} -H {{shellquote (printf \"Authorization: Bearer %s\" .env.GH_TOKEN)}}{{end}} {{if .flag.ref}}{{shellquote (printf \"%s/repos/%s/readme?ref=%s\" .var.base_url .arg.repo (urlpath .flag.ref))}}{{else}}{{shellquote (printf \"%s/repos/%s/readme\" .var.base_url .arg.repo)}}{{end}}"
        },
        {
          "name": "languages",
          "description": "Map of languages to byte counts.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $total := 0 }}{{ range $_, $b := .data }}{{ $total = add $total $b }}{{ end }}{{ $rows := list \"LANGUAGE\\tBYTES\\t%\" }}{{ range $lang, $bytes := .data }}{{ $rows = append $rows (printf \"%v\\t%v\\t%.1f%%\" $lang $bytes (mulf 100.0 (divf $bytes $total))) }}{{ end }}{{ tabwriter $rows }}"
              }
            ]
          },
          "entry": {
            "path": "/repos/{{.arg.repo}}/languages"
          }
        },
        {
          "name": "topics",
          "description": "List repository topics.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "list",
                "default": true,
                "template": "{{ range .data.names }}{{ . }}\n{{ end }}"
              }
            ]
          },
          "entry": {
            "path": "/repos/{{.arg.repo}}/topics"
          }
        }
      ]
    },

    {
      "name": "org",
      "description": "Read organization info.",
      "commands": [
        {
          "name": "get",
          "description": "Fetch an org.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "detail",
                "default": true,
                "template": "Login:       {{.data.login}}\nID:          {{.data.id}}\nName:        {{default \"-\" .data.name}}\nDescription: {{default \"-\" .data.description}}\nLocation:    {{default \"-\" .data.location}}\nBlog:        {{default \"-\" .data.blog}}\nMembers:     {{default 0 .data.followers}}    Repos: {{.data.public_repos}}\nCreated:     {{.data.created_at}}\n"
              }
            ]
          },
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}"
          }
        },
        {
          "name": "members",
          "description": "List public members.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "format": "user",
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}/public_members",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "repos",
          "description": "List org repositories.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "type", "type": "string", "default": "all", "description": "all|public|private|forks|sources|member." }
          ],
          "format": "repo",
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}/repos",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "type": "{{.flag.type}}"
            }
          }
        }
      ]
    },

    {
      "name": "search",
      "description": "Search across GitHub.",
      "commands": [
        {
          "name": "repos",
          "description": "Search repositories. QUERY accepts the full GitHub search syntax (e.g. `language:go stars:>1000`).",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "sort", "type": "string", "default": "", "description": "stars|forks|updated|help-wanted-issues." },
            { "name": "order", "type": "string", "default": "desc", "description": "asc|desc." }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $rows := list \"NAME\\tSTARS\\tLANG\\tDESCRIPTION\" }}{{ range .data.items }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\\t%v\" .full_name .stargazers_count (default \"-\" .language) (default \"\" .description)) }}{{ end }}{{ tabwriter $rows }}\n{{.data.total_count}} total"
              }
            ]
          },
          "entry": {
            "path": "/search/repositories",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}",
              "order": "{{.flag.order}}"
            }
          }
        },
        {
          "name": "code",
          "description": "Search code. Requires authentication.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $rows := list \"REPO\\tPATH\" }}{{ range .data.items }}{{ $rows = append $rows (printf \"%v\\t%v\" .repository.full_name .path) }}{{ end }}{{ tabwriter $rows }}\n{{.data.total_count}} total"
              }
            ]
          },
          "entry": {
            "path": "/search/code",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "issues",
          "description": "Search issues and pull requests.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "sort", "type": "string", "default": "", "description": "comments|reactions|created|updated." }
          ],
          "vars": {
            "filter": "walk(if type == \"object\" then with_entries(select((.key == \"repository_url\" or (.key | endswith(\"url\") | not)) and (.key | IN(\"node_id\",\"gravatar_id\",\"user_view_type\",\"site_admin\",\"performed_via_github_app\",\"active_lock_reason\",\"author_association\",\"temp_clone_token\",\"custom_properties\",\"issue_field_values\",\"permissions\",\"network_count\",\"pinned_comment\",\"reactions\",\"sub_issues_summary\",\"issue_dependencies_summary\") | not))) | if has(\"forks_count\") then del(.forks) else . end | if has(\"watchers_count\") then del(.watchers) else . end | if has(\"open_issues_count\") then del(.open_issues) else . end else . end)"
          },
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $base := printf \"%s/repos/\" .var.base_url }}{{ $rows := list \"REPO\\t#\\tSTATE\\tTITLE\" }}{{ range .data.items }}{{ $rows = append $rows (printf \"%v\\t#%v\\t%v\\t%v\" (default \"\" .repository_url | trimPrefix $base) .number .state .title) }}{{ end }}{{ tabwriter $rows }}\n{{.data.total_count}} total"
              }
            ]
          },
          "entry": {
            "path": "/search/issues",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}"
            }
          }
        },
        {
          "name": "users",
          "description": "Search users.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "format": {
            "input": "json",
            "views": [
              {
                "name": "table",
                "default": true,
                "template": "{{ $rows := list \"LOGIN\\tID\\tTYPE\" }}{{ range .data.items }}{{ $rows = append $rows (printf \"%v\\t%v\\t%v\" .login .id .type) }}{{ end }}{{ tabwriter $rows }}\n{{.data.total_count}} total"
              }
            ]
          },
          "entry": {
            "path": "/search/users",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        }
      ]
    },

    {
      "name": "rate-limit",
      "description": "Show the current rate-limit status. (RESET column is unix epoch seconds.)",
      "format": "rate",
      "entry": {
        "path": "/rate_limit"
      }
    }
  ]
}
