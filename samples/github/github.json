{
  "name": "github",
  "description": "Comfortable read-only wrapper for the GitHub REST API. Aggressively strips noise from responses: *url fields, GraphQL node_ids, empty gravatar_ids, duplicate counts, reaction breakdowns, permission objects, and other metadata that bloats output without adding value. Set $GITHUB_TOKEN / $GH_TOKEN for authenticated access (60 req/hr unauthenticated, 5000/hr authenticated). Set $GITHUB_API_URL to target a GitHub Enterprise Server instance.",

  "vars": {
    "base_url": "{{.env.GITHUB_API_URL | default \"https://api.github.com\"}}",
    "ua": "api-cli-github-example",
    "token": "{{ or .env.GITHUB_TOKEN .env.GH_TOKEN }}",
    "noise": "\"node_id\",\"gravatar_id\",\"user_view_type\",\"site_admin\",\"performed_via_github_app\",\"active_lock_reason\",\"author_association\",\"temp_clone_token\",\"custom_properties\",\"issue_field_values\",\"permissions\",\"_links\",\"network_count\",\"pinned_comment\",\"reactions\",\"sub_issues_summary\",\"issue_dependencies_summary\"",
    "keep": "false",
    "filter": "walk(if type == \"object\" then with_entries(select(((.key | endswith(\"url\") | not) and (.key | IN({{.var.noise}}) | not)) or ({{.var.keep}}))) | if has(\"forks_count\") then del(.forks) else . end | if has(\"watchers_count\") then del(.watchers) else . end | if has(\"open_issues_count\") then del(.open_issues) else . end else . end)"
  },

  "request": {
    "method": "GET",
    "url": "{{.var.base_url}}{{.entry.path}}",
    "query": { "from": "entry.query" },
    "headers": {
      "User-Agent": "{{.var.ua}}",
      "Accept": "application/vnd.github+json",
      "X-GitHub-Api-Version": "2022-11-28",
      "Authorization": "{{if .var.token}}Bearer {{.var.token}}{{end}}"
    },
    "response": { "jq": "{{.var.filter}}" }
  },

  "commands": [
    {
      "name": "user",
      "description": "Read user info.",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a user. Omit USERNAME to use /user (the authenticated viewer; requires a token).",
          "args": [
            { "name": "username", "type": "string", "description": "GitHub username." }
          ],
          "fields": [
            { "name": "login" },
            { "name": "id" },
            { "name": "name", "default": "-" },
            { "name": "company", "default": "-" },
            { "name": "location", "default": "-" },
            { "name": "bio", "default": "-" },
            { "name": "followers" },
            { "name": "following" },
            { "name": "repos", "from": "public_repos" },
            { "name": "created", "from": "created_at" }
          ],
          "entry": {
            "path": "{{if .arg.username}}/users/{{urlpath .arg.username}}{{else}}/user{{end}}"
          }
        },
        {
          "name": "repos",
          "description": "List a user's public repositories.",
          "args": [
            { "name": "username", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30, "description": "Items per page (max 100)." },
            { "name": "page", "short": "p", "type": "int", "default": 1, "description": "Page number." },
            { "name": "sort", "type": "string", "default": "updated", "description": "created|updated|pushed|full_name." }
          ],
          "fields": [
            { "name": "name", "from": "full_name" },
            { "name": "stars", "from": "stargazers_count" },
            { "name": "forks", "from": "forks_count", "priority": -1 },
            { "name": "lang", "from": "language", "default": "-" },
            { "name": "description", "default": "-", "priority": -2 }
          ],
          "entry": {
            "path": "/users/{{urlpath .arg.username}}/repos",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}"
            }
          }
        },
        {
          "name": "orgs",
          "description": "List a user's public organization memberships.",
          "args": [
            { "name": "username", "type": "string", "required": true }
          ],
          "fields": [
            { "name": "login" },
            { "name": "id" },
            { "name": "description", "default": "-" }
          ],
          "entry": {
            "path": "/users/{{urlpath .arg.username}}/orgs"
          }
        }
      ]
    },

    {
      "name": "repo",
      "description": "Read repository info.",
      "commands": [
        {
          "name": "get",
          "description": "Fetch a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "fields": [
            { "name": "repo", "from": "full_name" },
            { "name": "description", "default": "-" },
            { "name": "language", "default": "-" },
            { "name": "stars", "from": "stargazers_count" },
            { "name": "forks", "from": "forks_count" },
            { "name": "issues", "from": "open_issues_count" },
            { "name": "default", "from": "default_branch" },
            { "name": "license", "default": "-", "expr": "{{ with .license }}{{ .spdx_id }}{{ end }}" },
            { "name": "created", "from": "created_at" },
            { "name": "updated", "from": "updated_at" },
            { "name": "pushed", "from": "pushed_at" },
            { "name": "archived" },
            { "name": "fork" },
            { "name": "private" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}"
          }
        },
        {
          "name": "issues",
          "description": "List issues for a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "flags": [
            { "name": "state", "type": "string", "default": "open", "description": "open|closed|all." },
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "labels", "type": "string", "default": "", "description": "Comma-separated label names." }
          ],
          "fields": [
            { "name": "number" },
            { "name": "state" },
            { "name": "author", "from": "user.login" },
            { "name": "title" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/issues",
            "query": {
              "state": "{{.flag.state}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "labels": "{{.flag.labels}}"
            }
          }
        },
        {
          "name": "issue",
          "description": "Fetch a single issue.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "fields": [
            { "name": "number" },
            { "name": "state" },
            { "name": "title" },
            { "name": "author", "from": "user.login" },
            { "name": "created", "from": "created_at" },
            { "name": "updated", "from": "updated_at" },
            { "name": "labels", "expr": "{{ range $i, $l := .labels }}{{ if $i }}, {{ end }}{{ $l.name }}{{ end }}" },
            { "name": "body", "default": "" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/issues/{{.arg.number}}"
          }
        },
        {
          "name": "prs",
          "description": "List pull requests for a repository.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." }
          ],
          "flags": [
            { "name": "state", "type": "string", "default": "open", "description": "open|closed|all." },
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "fields": [
            { "name": "number" },
            { "name": "state" },
            { "name": "author", "from": "user.login" },
            { "name": "title" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/pulls",
            "query": {
              "state": "{{.flag.state}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "pr",
          "description": "Fetch a single pull request: description, comment counts, and diff size.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "fields": [
            { "name": "number" },
            { "name": "title" },
            { "name": "author", "from": "user.login" },

            { "name": "state", "show_in": "json" },
            { "name": "draft", "show_in": "json" },
            { "name": "merged", "show_in": "json" },
            { "name": "state", "show_in": "!json", "expr": "{{ .state }}{{ if .draft }}, draft{{ end }}{{ if .merged }}, merged{{ end }}" },

            { "name": "head", "from": "head.ref", "show_in": "json" },
            { "name": "base", "from": "base.ref", "show_in": "json" },
            { "name": "branch", "show_in": "!json", "expr": "{{ .head.ref }} -> {{ .base.ref }}" },

            { "name": "additions", "default": "0", "show_in": "json" },
            { "name": "deletions", "default": "0", "show_in": "json" },
            { "name": "changed_files", "default": "0", "show_in": "json" },
            { "name": "diff", "show_in": "!json", "expr": "+{{ .additions }} -{{ .deletions }} across {{ .changed_files }} file(s)" },

            { "name": "created", "from": "created_at" },
            { "name": "updated", "from": "updated_at" },
            { "name": "comments", "default": "0" },
            { "name": "review_comments", "default": "0" },
            { "name": "commits", "default": "0" },
            { "name": "labels", "expr": "{{ range $i, $l := .labels }}{{ if $i }}, {{ end }}{{ $l.name }}{{ end }}" },
            { "name": "body", "default": "", "priority": -1 }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/pulls/{{.arg.number}}"
          }
        },
        {
          "name": "pr-diff",
          "description": "Fetch the unified diff for a pull request.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "request": {
            "method": "GET",
            "url": "{{.var.base_url}}/repos/{{.arg.repo}}/pulls/{{.arg.number}}",
            "headers": {
              "User-Agent": "{{.var.ua}}",
              "Accept": "application/vnd.github.diff",
              "Authorization": "{{if .var.token}}Bearer {{.var.token}}{{end}}"
            }
          }
        },
        {
          "name": "pr-comments",
          "description": "List a pull request's comments. Defaults to the conversation (issue) comments; pass --review for inline code-review comments.",
          "args": [
            { "name": "repo", "type": "string", "required": true, "description": "owner/name." },
            { "name": "number", "type": "int", "required": true }
          ],
          "flags": [
            { "name": "review", "short": "r", "type": "bool", "default": false, "description": "List inline code-review comments instead of conversation comments." },
            { "name": "limit", "short": "n", "type": "int", "default": 30, "description": "Items per page (max 100)." },
            { "name": "page", "short": "p", "type": "int", "default": 1, "description": "Page number." }
          ],
          "fields": [
            { "name": "author", "from": "user.login" },
            { "name": "on", "default": "-", "expr": "{{ .path }}{{ with .line }}:{{ . }}{{ end }}" },
            { "name": "created", "from": "created_at" },
            { "name": "body" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/{{if .flag.review}}pulls/{{.arg.number}}/comments{{else}}issues/{{.arg.number}}/comments{{end}}",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "releases",
          "description": "List releases.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "fields": [
            { "name": "tag", "from": "tag_name" },
            { "name": "name", "default": "-" },
            { "name": "published", "from": "published_at" },
            { "name": "draft" },
            { "name": "prerelease" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/releases",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "release",
          "description": "Fetch a release by tag, or `latest`.",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "tag", "type": "string", "required": true, "description": "Tag name, or `latest`." }
          ],
          "fields": [
            { "name": "tag", "from": "tag_name" },
            { "name": "name", "default": "-" },
            { "name": "published", "from": "published_at" },
            { "name": "author", "from": "author.login" },
            { "name": "draft" },
            { "name": "prerelease" },
            { "name": "body", "default": "" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/releases/{{if eq .arg.tag \"latest\"}}latest{{else}}tags/{{urlpath .arg.tag}}{{end}}"
          }
        },
        {
          "name": "commits",
          "description": "List recent commits.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "branch", "type": "string", "default": "", "description": "Branch / SHA / tag to start from." },
            { "name": "path", "type": "string", "default": "", "description": "Restrict to commits touching this path." }
          ],
          "fields": [
            { "name": "sha", "truncate": 7 },
            { "name": "author", "from": "commit.author.name" },
            { "name": "date", "from": "commit.author.date" },
            { "name": "message", "from": "commit.message", "firstline": true }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/commits",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sha": "{{.flag.branch}}",
              "path": "{{.flag.path}}"
            }
          }
        },
        {
          "name": "commit",
          "description": "Fetch a single commit.",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "sha", "type": "string", "required": true, "description": "Commit SHA, branch, or tag." }
          ],
          "fields": [
            { "name": "sha" },
            { "name": "name", "from": "commit.author.name", "show_in": "json" },
            { "name": "email", "from": "commit.author.email", "show_in": "json" },
            { "name": "author", "show_in": "!json", "expr": "{{ .commit.author.name }} <{{ .commit.author.email }}>" },
            { "name": "date", "from": "commit.author.date" },
            { "name": "message", "from": "commit.message" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/commits/{{urlpath .arg.sha}}"
          }
        },
        {
          "name": "branches",
          "description": "List branches.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "fields": [
            { "name": "name" },
            { "name": "sha", "from": "commit.sha", "truncate": 7 },
            { "name": "protected" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/branches",
            "query": { "per_page": "100" }
          }
        },
        {
          "name": "tags",
          "description": "List tags.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "fields": [
            { "name": "name" },
            { "name": "sha", "from": "commit.sha", "truncate": 7 }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/tags",
            "query": { "per_page": "100" }
          }
        },
        {
          "name": "contents",
          "description": "Fetch a file or directory listing. Omit PATH to list the repo root; otherwise a slash-delimited path (not URL-encoded). With no fields, a directory listing is an array (table) and a single file is an object (list); the shape decides.",
          "args": [
            { "name": "repo", "type": "string", "required": true },
            { "name": "path", "type": "string", "description": "File or directory path within the repo. Omit for the root listing." }
          ],
          "flags": [
            { "name": "ref", "short": "r", "type": "string", "default": "", "description": "Branch / SHA / tag." }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/contents{{if .arg.path}}/{{.arg.path}}{{end}}",
            "query": { "ref": "{{.flag.ref}}" }
          }
        },
        {
          "name": "readme",
          "description": "Fetch the rendered raw README.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "ref", "short": "r", "type": "string", "default": "", "description": "Branch / SHA / tag." }
          ],
          "request": {
            "method": "GET",
            "url": "{{.var.base_url}}/repos/{{.arg.repo}}/readme",
            "query": { "ref": "{{.flag.ref}}" },
            "headers": {
              "User-Agent": "{{.var.ua}}",
              "Accept": "application/vnd.github.raw",
              "Authorization": "{{if .var.token}}Bearer {{.var.token}}{{end}}"
            }
          }
        },
        {
          "name": "languages",
          "description": "Map of languages to byte counts. over=\"data\" walks the map with @key/@value; percent is an aggregate computed with the expr escape hatch.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "over": "data",
          "fields": [
            { "name": "language", "from": "@key" },
            { "name": "bytes", "from": "@value" },
            { "name": "percent", "expr": "{{ $t := 0 }}{{ range $.data }}{{ $t = add $t . }}{{ end }}{{ printf \"%.1f%%\" (mulf 100.0 (divf . $t)) }}" }
          ],
          "entry": {
            "path": "/repos/{{.arg.repo}}/languages"
          }
        },
        {
          "name": "topics",
          "description": "List repository topics. The records are the scalar strings at data.names.",
          "args": [
            { "name": "repo", "type": "string", "required": true }
          ],
          "over": "data.names",
          "entry": {
            "path": "/repos/{{.arg.repo}}/topics"
          }
        }
      ]
    },

    {
      "name": "org",
      "description": "Read organization info.",
      "commands": [
        {
          "name": "get",
          "description": "Fetch an org.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "fields": [
            { "name": "login" },
            { "name": "id" },
            { "name": "name", "default": "-" },
            { "name": "description", "default": "-" },
            { "name": "location", "default": "-" },
            { "name": "blog", "default": "-" },
            { "name": "members", "from": "followers" },
            { "name": "repos", "from": "public_repos" },
            { "name": "created", "from": "created_at" }
          ],
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}"
          }
        },
        {
          "name": "members",
          "description": "List public members.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "fields": [
            { "name": "login" },
            { "name": "id" },
            { "name": "type" }
          ],
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}/public_members",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "repos",
          "description": "List org repositories.",
          "args": [
            { "name": "org", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "type", "type": "string", "default": "all", "description": "all|public|private|forks|sources|member." }
          ],
          "fields": [
            { "name": "name", "from": "full_name" },
            { "name": "stars", "from": "stargazers_count" },
            { "name": "forks", "from": "forks_count", "priority": -1 },
            { "name": "lang", "from": "language", "default": "-" },
            { "name": "description", "default": "-", "priority": -2 }
          ],
          "entry": {
            "path": "/orgs/{{urlpath .arg.org}}/repos",
            "query": {
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "type": "{{.flag.type}}"
            }
          }
        }
      ]
    },

    {
      "name": "search",
      "description": "Search across GitHub.",
      "commands": [
        {
          "name": "repos",
          "description": "Search repositories. QUERY accepts the full GitHub search syntax (e.g. `language:go stars:>1000`).",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "sort", "type": "string", "default": "", "description": "stars|forks|updated|help-wanted-issues." },
            { "name": "order", "type": "string", "default": "desc", "description": "asc|desc." }
          ],
          "over": "data.items",
          "footer": "{{.data.total_count}} total",
          "fields": [
            { "name": "name", "from": "full_name" },
            { "name": "stars", "from": "stargazers_count" },
            { "name": "lang", "from": "language", "default": "-" },
            { "name": "description", "default": "-" }
          ],
          "entry": {
            "path": "/search/repositories",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}",
              "order": "{{.flag.order}}"
            }
          }
        },
        {
          "name": "code",
          "description": "Search code. Requires authentication.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "over": "data.items",
          "footer": "{{.data.total_count}} total",
          "fields": [
            { "name": "repo", "from": "repository.full_name" },
            { "name": "path" }
          ],
          "entry": {
            "path": "/search/code",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        },
        {
          "name": "issues",
          "description": "Search issues and pull requests.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 },
            { "name": "sort", "type": "string", "default": "", "description": "comments|reactions|created|updated." }
          ],
          "vars": {
            "keep": ".key == \"repository_url\""
          },
          "over": "data.items",
          "footer": "{{.data.total_count}} total",
          "fields": [
            { "name": "repo", "expr": "{{ .repository_url | default \"\" | trimPrefix (printf \"%s/repos/\" $.var.base_url) }}" },
            { "name": "number" },
            { "name": "state" },
            { "name": "title" }
          ],
          "entry": {
            "path": "/search/issues",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}",
              "sort": "{{.flag.sort}}"
            }
          }
        },
        {
          "name": "users",
          "description": "Search users.",
          "args": [
            { "name": "query", "type": "string", "required": true }
          ],
          "flags": [
            { "name": "limit", "short": "n", "type": "int", "default": 30 },
            { "name": "page", "short": "p", "type": "int", "default": 1 }
          ],
          "over": "data.items",
          "footer": "{{.data.total_count}} total",
          "fields": [
            { "name": "login" },
            { "name": "id" },
            { "name": "type" }
          ],
          "entry": {
            "path": "/search/users",
            "query": {
              "q": "{{.arg.query}}",
              "per_page": "{{.flag.limit}}",
              "page": "{{.flag.page}}"
            }
          }
        }
      ]
    },

    {
      "name": "rate-limit",
      "description": "Show the current rate-limit status. (RESET column is unix epoch seconds.)",
      "over": "data.resources",
      "fields": [
        { "name": "resource", "from": "@key" },
        { "name": "limit" },
        { "name": "remaining" },
        { "name": "reset" }
      ],
      "entry": {
        "path": "/rate_limit"
      }
    }
  ]
}
