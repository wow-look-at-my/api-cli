FROM alpine:3.21
ARG TARGETOS=linux
ARG TARGETARCH=amd64
ADD https://pazer.build/dl/api-cli/latest/${TARGETOS}/${TARGETARCH} /usr/local/bin/api-cli
RUN chmod +x /usr/local/bin/api-cli && apk add --no-cache curl jq
COPY samples/github/github.json /github.json
ENTRYPOINT ["api-cli", "--config", "/github.json", "--mcp"]
CMD ["stdio"]
